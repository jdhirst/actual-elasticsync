# Actual Budget
# Your self-hosted Actual Budget server URL (no trailing slash)
ACTUAL_ENDPOINT="https://your-actual-server.example.com"

# Your Actual Budget server password
ACTUAL_PASSWORD="your-server-password"

# The Sync ID of the budget file to sync.
# Find it in Actual Budget: Settings → Show advanced settings → Sync ID
ACTUAL_BUDGET_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Elasticsearch
# Your Elasticsearch endpoint (include port if non-standard)
ES_ENDPOINT="https://your-elasticsearch.example.com:443"

# Elasticsearch API key (Base64-encoded id:api_key)
# Create one in Kibana: Stack Management → API Keys
ES_API_KEY="your-base64-encoded-api-key"
